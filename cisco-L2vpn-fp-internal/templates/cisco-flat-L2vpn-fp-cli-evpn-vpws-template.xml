<config-template xmlns="http://tail-f.com/ns/config/1.0">
  <devices xmlns="http://tail-f.com/ns/ncs">
    <device>
      <name>{pe}</name>
      <?set DEVICE_NAME={string(pe)}?>
      <?set DEFAULT_INTF_DESC='T-SDN Interface'?>
      <?set SERVICE_NAME={string(../../name)}?>
      <?if {string-length($SERVICE_NAME)>14 and starts-with($SERVICE_NAME,'L2NM-') and (substring($SERVICE_NAME, (string-length($SERVICE_NAME) - 8))='-internal')}?>
        <?set SERVICE_NAME={substring($SERVICE_NAME,6,string-length($SERVICE_NAME)-14)}?>
      <?end?>
      <config>
        <?if {sr-te/odn}?>
          <extcommunity-set xmlns="http://tail-f.com/ned/cisco-ios-xr" foreach="{sr-te/odn/route-policy/statements/statement}">
            <?if {actions/bgp-actions/set-ext-community}?>
            <?set COLOR_TAG={actions/bgp-actions/set-ext-community/tag-value}?>
            <?set COLOR_CO_FLAG={actions/bgp-actions/set-ext-community/co-flag}?>
            <opaque when="{$COLOR_TAG!=''}">
              <name>COLOR_{$COLOR_TAG}</name>
              <?if {$COLOR_CO_FLAG!=''}?>
                <set>
                  <value>{concat($COLOR_TAG, " co-flag ", $COLOR_CO_FLAG)}</value>
                </set>
              <?else?>
                <set>
                  <value>{$COLOR_TAG}</value>
                </set>
              <?end?>
            </opaque>
            <?end?>
          </extcommunity-set>
        <?end?>
